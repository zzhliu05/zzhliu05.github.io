---
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import DynamicBackground from '../components/DynamicBackground.astro';

interface Props {
  title?: string;
  description?: string;
}

const siteTitle = 'zzhliu05 的博客';
const { title = siteTitle, description = '一个记录数学、编程与思考的中文博客。' } = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} - ${siteTitle}`;
const isHomePage = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <DynamicBackground />
    <header class:list={['site-header', { 'site-header--home': isHomePage }]}>
      <div class="container header-inner">
        <a class="site-title" href="/">zzhliu05 的博客</a>
        <nav class="site-nav" aria-label="主导航">
          <a href="/">首页</a>
          <a href="/tags/">标签</a>
        </nav>
      </div>
    </header>
    <div
      class:list={['site-banner', { 'site-banner--home': isHomePage }]}
      aria-hidden={isHomePage ? undefined : 'true'}
    >
      <img src="/banner.jpg" alt="" />
      {isHomePage && (
        <>
          <div class="site-banner__content">
            <p>记录数学、编程与思考</p>
            <h1>zzhliu05 的博客</h1>
          </div>
          <a class="site-banner__scroll" href="#content" aria-label="查看文章">⌄</a>
        </>
      )}
    </div>
    <main class="container" id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">© {new Date().getFullYear()} zzhliu05</div>
    </footer>
  </body>
</html>
