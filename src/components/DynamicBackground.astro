<div class="dynamic-background" id="dynamic-background" aria-hidden="true"></div>

<script>
  import p5 from 'p5';

  const mount = document.querySelector<HTMLElement>('#dynamic-background');

  if (mount && !mount.dataset.ready) {
    mount.dataset.ready = 'true';

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sketch = (p: p5) => {
      type Particle = {
        x: number;
        y: number;
        vx: number;
        vy: number;
        radius: number;
      };

      let particles: Particle[] = [];
      let accent = '#1f5f8b';

      const createParticles = () => {
        const area = p.width * p.height;
        const density = window.innerWidth < 720 ? 34000 : 25000;
        const count = Math.max(18, Math.min(72, Math.floor(area / density)));

        particles = Array.from({ length: count }, () => ({
          x: p.random(p.width),
          y: p.random(p.height),
          vx: p.random(-0.18, 0.18),
          vy: p.random(-0.14, 0.14),
          radius: p.random(1, 2.2)
        }));
      };

      p.setup = () => {
        const canvas = p.createCanvas(window.innerWidth, window.innerHeight);
        canvas.attribute('aria-hidden', 'true');
        p.pixelDensity(Math.min(window.devicePixelRatio, 2));
        accent = getComputedStyle(document.documentElement).getPropertyValue('--link').trim() || accent;
        createParticles();

        if (reduceMotion) {
          p.noLoop();
        }
      };

      p.draw = () => {
        p.clear();
        const color = p.color(accent);

        for (let i = 0; i < particles.length; i += 1) {
          const particle = particles[i];

          if (!reduceMotion) {
            particle.x += particle.vx;
            particle.y += particle.vy;
          }

          if (particle.x < -8) particle.x = p.width + 8;
          if (particle.x > p.width + 8) particle.x = -8;
          if (particle.y < -8) particle.y = p.height + 8;
          if (particle.y > p.height + 8) particle.y = -8;

          color.setAlpha(58);
          p.noStroke();
          p.fill(color);
          p.circle(particle.x, particle.y, particle.radius * 2);

          for (let j = i + 1; j < particles.length; j += 1) {
            const other = particles[j];
            const distance = p.dist(particle.x, particle.y, other.x, other.y);
            const threshold = window.innerWidth < 720 ? 95 : 125;

            if (distance < threshold) {
              color.setAlpha(p.map(distance, 0, threshold, 26, 0));
              p.stroke(color);
              p.strokeWeight(0.7);
              p.line(particle.x, particle.y, other.x, other.y);
            }
          }
        }
      };

      p.windowResized = () => {
        p.resizeCanvas(window.innerWidth, window.innerHeight);
        createParticles();

        if (reduceMotion) {
          p.redraw();
        }
      };
    };

    new p5(sketch, mount);
  }
</script>
