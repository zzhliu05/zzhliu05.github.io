<div class="dynamic-background" id="dynamic-background" aria-hidden="true"></div>

<script>
  import p5 from 'p5';

  const mount = document.querySelector<HTMLElement>('#dynamic-background');

  if (mount && !mount.dataset.ready) {
    mount.dataset.ready = 'true';

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const sketch = (p: p5) => {
      type Boid = {
        position: p5.Vector;
        velocity: p5.Vector;
        acceleration: p5.Vector;
        color: p5.Color;
        size: number;
      };

      const palette = ['#ef476f', '#f59e0b', '#06a77d', '#118ab2', '#6d5dfc', '#d946ef'];
      const perceptionRadius = 74;
      const separationRadius = 30;
      const maxSpeed = 1.35;
      const maxForce = 0.035;
      let boids: Boid[] = [];

      const createBoids = () => {
        const area = p.width * p.height;
        const density = window.innerWidth < 720 ? 24500 : 20500;
        const count = Math.max(24, Math.min(90, Math.floor(area / density)));

        boids = Array.from({ length: count }, (_, index) => {
          const velocity = p5.Vector.random2D().setMag(p.random(0.65, maxSpeed));
          return {
            position: p.createVector(p.random(p.width), p.random(p.height)),
            velocity,
            acceleration: p.createVector(),
            color: p.color(palette[index % palette.length]),
            size: p.random(4.5, 7)
          };
        });
      };

      const steerToward = (boid: Boid, target: p5.Vector) => {
        if (target.magSq() === 0) return target;
        target.setMag(maxSpeed);
        target.sub(boid.velocity);
        target.limit(maxForce);
        return target;
      };

      const flock = (boid: Boid) => {
        const alignment = p.createVector();
        const cohesion = p.createVector();
        const separation = p.createVector();
        let neighbors = 0;
        let closeNeighbors = 0;

        for (const other of boids) {
          if (other === boid) continue;

          const distance = p5.Vector.dist(boid.position, other.position);
          if (distance > 0 && distance < perceptionRadius) {
            alignment.add(other.velocity);
            cohesion.add(other.position);
            neighbors += 1;
          }

          if (distance > 0 && distance < separationRadius) {
            const away = p5.Vector.sub(boid.position, other.position);
            away.div(distance * distance);
            separation.add(away);
            closeNeighbors += 1;
          }
        }

        if (neighbors > 0) {
          alignment.div(neighbors);
          cohesion.div(neighbors).sub(boid.position);
          boid.acceleration.add(steerToward(boid, alignment).mult(0.95));
          boid.acceleration.add(steerToward(boid, cohesion).mult(0.72));
        }

        if (closeNeighbors > 0) {
          separation.div(closeNeighbors);
          boid.acceleration.add(steerToward(boid, separation).mult(1.45));
        }
      };

      const wrapAround = (boid: Boid) => {
        const margin = boid.size * 2;
        if (boid.position.x < -margin) boid.position.x = p.width + margin;
        if (boid.position.x > p.width + margin) boid.position.x = -margin;
        if (boid.position.y < -margin) boid.position.y = p.height + margin;
        if (boid.position.y > p.height + margin) boid.position.y = -margin;
      };

      const drawBoid = (boid: Boid) => {
        const heading = boid.velocity.heading() + p.HALF_PI;
        boid.color.setAlpha(112);

        p.push();
        p.translate(boid.position.x, boid.position.y);
        p.rotate(heading);
        p.noStroke();
        p.fill(boid.color);
        p.triangle(
          0,
          -boid.size * 1.35,
          -boid.size * 0.72,
          boid.size,
          boid.size * 0.72,
          boid.size
        );
        p.pop();
      };

      p.setup = () => {
        const canvas = p.createCanvas(window.innerWidth, window.innerHeight);
        canvas.attribute('aria-hidden', 'true');
        p.pixelDensity(Math.min(window.devicePixelRatio, 2));
        createBoids();

        if (reduceMotion) {
          p.noLoop();
        }
      };

      p.draw = () => {
        p.clear();

        for (const boid of boids) {
          if (!reduceMotion) {
            flock(boid);
            boid.velocity.add(boid.acceleration);
            boid.velocity.limit(maxSpeed);
            boid.position.add(boid.velocity);
            boid.acceleration.mult(0);
          }

          wrapAround(boid);
          drawBoid(boid);
        }
      };

      p.windowResized = () => {
        p.resizeCanvas(window.innerWidth, window.innerHeight);
        createBoids();

        if (reduceMotion) {
          p.redraw();
        }
      };
    };

    new p5(sketch, mount);
  }
</script>
